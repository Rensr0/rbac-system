# RBAC 权限管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rbac_system
DB_USER=root
DB_PASS=your_secure_password_here

# 应用配置
APP_ENV=production
APP_DEBUG=false

# 时区
TIMEZONE=Asia/Shanghai

# Session 配置
SESSION_LIFETIME=7200

# CORS 配置（生产环境请设置实际域名）
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
